    "@aws-sdk/util-dynamodb": "^3.985.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "googleapis": "^126.0.0",
    "jsonwebtoken": "^9.0.3",
