# Environment Variables

# Server
PORT=3001
NODE_ENV=development

# Google Sheets API
# Sesiones: memory (desarrollo) | dynamodb (producción Lambda)
# SESSION_STORE=memory
# SESSIONS_TABLE_NAME=bee-tracked-sessions-prod

# Sheet: hoja "BeeZero" (compartir con bee-tracked-service@beezero.iam.gserviceaccount.com)
# https://docs.google.com/spreadsheets/d/1L69tZzVSHlhuKGP9MCdcezOGPsYyjC2Mm-i03Hm5tM8/edit
GOOGLE_SHEET_ID=1L69tZzVSHlhuKGP9MCdcezOGPsYyjC2Mm-i03Hm5tM8
# Opción A: Ruta al archivo JSON (recomendado en desarrollo)
GOOGLE_CREDENTIALS_PATH=../beezero-1710ecf4e5e0.json
# Opción B: JSON completo en variable (útil en AWS/Secrets Manager)
# GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"beezero",...}
# Cuenta de servicio: bee-tracked-service@beezero.iam.gserviceaccount.com

# Carreras_bikers: una pestaña por biker (Ecodelivery)
# Carreras_drivers: una pestaña por driver/abejita (BeeZero). Si no se define, usa CARRERAS_BIKERS_SHEET_ID
# https://docs.google.com/spreadsheets/d/1OkM4FLSe0CsLo8w4o50xcVdzsUcHVzpaYRqhGBwJRcs/edit
CARRERAS_BIKERS_SHEET_ID=1OkM4FLSe0CsLo8w4o50xcVdzsUcHVzpaYRqhGBwJRcs
# Mismo ID por defecto; define solo si diverge del de bikers
CARRERAS_DRIVERS_SHEET_ID=1OkM4FLSe0CsLo8w4o50xcVdzsUcHVzpaYRqhGBwJRcs

# Registros y Kilometraje (Ecodelivery - carreras del día y registro de km)
# https://docs.google.com/spreadsheets/d/1a8M19WHhfM2SWKSiWbTIpVU76gdAFCJ9uv7y0fnPA4g/edit
REGISTROS_SHEET_ID=1a8M19WHhfM2SWKSiWbTIpVU76gdAFCJ9uv7y0fnPA4g

# AWS S3 (fotos BeeZero: beezero/tablero/ y beezero/danos/)
# Ver AWS_SETUP.md para crear bucket e IAM
AWS_REGION=us-east-1
AWS_S3_BUCKET=bee-tracked-photos
# Credenciales (opcional en Lambda si usa IAM role):
AWS_ACCESS_KEY_ID=tu_access_key_id
AWS_SECRET_ACCESS_KEY=tu_secret_access_key

# Frontend URL (para CORS)
FRONTEND_URL=http://localhost:3000

# DynamoDB (desarrollo local — usar -dev o -prod según tu stage)
# SESSIONS_TABLE_NAME=bee-tracked-sessions-prod
# TURNOS_TABLE=bee-tracked-turnos-prod
# CARRERAS_TABLE=bee-tracked-carreras-prod
# Migración híbrida Sheets → DynamoDB
# DYNAMO_WRITE_ENABLED=true   # dual write: Sheets + DynamoDB en cada registro nuevo
# DYNAMO_READ_ENABLED=false   # activar true después de correr migrate-sheets-to-dynamo.js
# PUSH_SUBS_TABLE=bee-tracked-push-subs-prod

# Web Push (desarrollo local — en prod se leen de Secrets Manager bee-tracked/vapid)
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@beezero.com
# KILOMETRAJES_TABLE=bee-tracked-kilometrajes-prod
# ANUNCIOS_TABLE=bee-tracked-anuncios-prod
# LECTURAS_TABLE=bee-tracked-lecturas-prod
# PERMISOS_TABLE=bee-tracked-permisos-prod
# USERS_TABLE=bee-tracked-users-prod
# AUDIT_TABLE=bee-tracked-audit-prod

# Amazon Cognito (validación JWT para usuarios Ecodelivery)
COGNITO_USER_POOL_ID=us-east-1_REsVOVqcY
COGNITO_REGION=us-east-1

# Email al solicitar permiso (Gmail SMTP; en prod también en SSM /bee-tracked/GMAIL_*)
# GMAIL_USER=tu-cuenta@gmail.com
# GMAIL_APP_PASSWORD=contraseña_de_aplicacion_16_caracteres_sin_espacios
# PERMISO_NOTIFY_EMAILS=alejis812@gmail.com,drea.79a@gmail.com,hola.beezero@gmail.com

# Ecodelivery Credentials CSV (opcional: path personalizado)
# ECODELIVERY_CREDENTIALS_PATH=../data/ecodelivery-credentials.csv

# Sheet de usuarios (para sync-cognito-from-sheet.js)
# https://docs.google.com/spreadsheets/d/1O43y1u_iIrTNSA0C0uSyueeADDLEx2mdGNs5a3pnfzw
# USUARIOS_SHEET_ID=1O43y1u_iIrTNSA0C0uSyueeADDLEx2mdGNs5a3pnfzw
